rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ─────────────────────────────────────────────────
    function isStaff() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/staff_index/$(request.auth.uid));
    }

    function isMemberOfTeam(teamId) {
      return teamId != null &&
        exists(/databases/$(database)/documents/teams/$(teamId)) && (
          (get(/databases/$(database)/documents/teams/$(teamId)).data.keys().hasAll(['memberUids']) &&
           get(/databases/$(database)/documents/teams/$(teamId)).data.memberUids.hasAny([request.auth.uid]))
          ||
          get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == request.auth.uid
        );
    }

    // ── Usuários ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:  if request.auth != null && (request.auth.uid == userId || isStaff());
      allow list: if request.auth != null && isStaff();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
      allow update: if request.auth != null && (
        // Staff pode alterar qualquer campo (incluindo plan e staffRole)
        isStaff() ||
        // Próprio usuário pode atualizar, EXCETO campos protegidos
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(
           ['plan', 'staffRole', 'boostCredits', 'boostActiveUntil',
            'effectivePriority', 'monthlyMatchesCount', 'monthlyScore']
         ))
      );
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Equipes ────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // GET: membro, criador ou staff
      allow get: if request.auth != null && (
        (resource.data.keys().hasAll(['memberUids']) &&
         resource.data.memberUids.hasAny([request.auth.uid])) ||
        resource.data.createdBy == request.auth.uid ||
        isStaff()
      );
      // LIST: qualquer autenticado pode fazer queries filtradas
      // (ex: where memberUids array-contains uid, ou where inviteCode == code)
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource == null ||
        (resource.data.keys().hasAll(['memberUids']) &&
         resource.data.memberUids.hasAny([request.auth.uid])) ||
        resource.data.createdBy == request.auth.uid
      );
    }
    
    // CORREÇÃO DE SEGURANÇA: Apenas membros ou staff podem acessar subcoleções de equipes
    match /teams/{teamId}/{document=**} {
      allow read, write: if isStaff() || isMemberOfTeam(teamId);
    }

    // ── Tickets ────────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        resource.data.uid       == request.auth.uid ||
        resource.data.authorUid == request.auth.uid ||
        isStaff()
      );
    }
    match /tickets/{ticketId}/replies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
    }

    // ── Perfis de talentos ─────────────────────────────────────────────────
    match /talent_profiles/{uid} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Mensagens entre talentos ───────────────────────────────────────────
    match /talent_messages/{msgId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
    }

    // ── Convites de talentos ───────────────────────────────────────────────
    match /talent_invites/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Perfis públicos de equipes ─────────────────────────────────────────
    match /team_profiles/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        (exists(/databases/$(database)/documents/team_profiles/$(teamId)) && resource.data.ownerUid == request.auth.uid) ||
        (!exists(/databases/$(database)/documents/team_profiles/$(teamId)) && exists(/databases/$(database)/documents/teams/$(teamId)) && get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == request.auth.uid) ||
        (!exists(/databases/$(database)/documents/team_profiles/$(teamId)) && request.resource.data.ownerUid == request.auth.uid)
      );
    }

    // ── Likes de equipes ───────────────────────────────────────────────────
    match /team_likes/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Interesses de Match (artista <-> equipe) ───────────────────────────
    match /interests/{interestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid || resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid || resource.data.fromUserUid == request.auth.uid ||
        resource.data.toUserUid == request.auth.uid || resource.data.senderUid == request.auth.uid ||
        isMemberOfTeam(resource.data.toTeamId) || isMemberOfTeam(resource.data.fromTeamId) || isStaff()
      );
      allow update: if request.auth != null && (
        resource.data.fromUid == request.auth.uid || resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid || resource.data.fromUserUid == request.auth.uid ||
        resource.data.toUserUid == request.auth.uid || resource.data.senderUid == request.auth.uid ||
        isMemberOfTeam(resource.data.toTeamId) || isMemberOfTeam(resource.data.fromTeamId) || isStaff()
      );
      allow delete: if request.auth != null && (
        resource.data.fromUid == request.auth.uid || resource.data.fromId == request.auth.uid ||
        resource.data.fromUserUid == request.auth.uid || resource.data.senderUid == request.auth.uid ||
        resource.data.toUserUid == request.auth.uid || isMemberOfTeam(resource.data.fromTeamId)
      );
    }

    // ── Matches confirmados ────────────────────────────────────────────────
    match /matches/{matchId} {
      allow create: if request.auth != null;
      // CORREÇÃO DE SEGURANÇA: Apenas os envolvidos no match ou staff podem ler
      allow read: if isStaff() || (
        request.auth != null && (
          resource.data.userUid == request.auth.uid ||
          resource.data.teamOwnerId == request.auth.uid ||
          isMemberOfTeam(resource.data.teamId)
        )
      );
      allow update, delete: if request.auth != null && (
        resource == null || resource.data.userUid == request.auth.uid ||
        resource.data.teamOwnerId == request.auth.uid || isMemberOfTeam(resource.data.teamId)
      );
    }

    // ── Chat do Match ─────────────────────────────────────────────────────
    match /matches/{matchId}/messages/{msgId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/matches/$(matchId)).data.userUid == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(matchId)).data.teamOwnerId == request.auth.uid ||
        isMemberOfTeam(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId)
      );
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid && (
        get(/databases/$(database)/documents/matches/$(matchId)).data.userUid == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(matchId)).data.teamOwnerId == request.auth.uid ||
        isMemberOfTeam(get(/databases/$(database)/documents/matches/$(matchId)).data.teamId)
      );
      allow delete: if request.auth != null && resource.data.from == request.auth.uid;
    }

    // ── Chat Privado ──────────────────────────────────────────────────────
    match /pm_chats/{chatId} {
      allow read, write: if request.auth != null && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
    }
    match /pm_chats/{chatId}/messages/{msgId} {
      allow read: if request.auth != null && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
      allow create: if request.auth != null && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid) && request.resource.data.from == request.auth.uid;
      allow delete: if request.auth != null && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
    }

    // ── Conversas Privadas (metadados) ───────────────────────────────────
    match /pm_convs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /pm_convs/{userId}/convs/{convId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Notificações do usuário ────────────────────────────────────────────
    match /user_notifications/{userId}/notifs/{notifId} {
      allow read, delete, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
    match /user_notifications/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Staff ─────────────────────────────────────────────────────────────
    match /staff_index/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == uid || isStaff());
    }
    match /staff_log/{logId} {
      allow read, create: if request.auth != null && isStaff();
      allow update, delete: if false;
    }
  }
}
